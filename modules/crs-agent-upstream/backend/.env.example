# CRS Agent backend configuration
# This is the single backend config file used by both root `npm start`
# and direct backend uvicorn/pytest execution.


# Database
CRS_MYSQL_HOST=127.0.0.1
CRS_MYSQL_PORT=3306
CRS_MYSQL_USER=root
CRS_MYSQL_PASSWORD=
CRS_MYSQL_DATABASE=crs_agent


# Redis
CRS_REDIS_URL=redis://127.0.0.1:6379/0


# Agent
CRS_AGENT_MODEL=openrouter:google/gemini-3.1-flash-lite-preview


# Auth
CRS_USER_AUTH_ENABLED=true


# Parameter Query
CRS_PARAM_QUERY_ENABLED=true
CRS_PARAM_QUERY_SYNC_ON_STARTUP=true
CRS_PARAM_QUERY_PARSER_VERSION=2026-03-26-v2
CRS_PARAM_QUERY_EXTERNAL_MYSQL_HOST=sh-test-mysql.51gonggui.com
CRS_PARAM_QUERY_EXTERNAL_MYSQL_PORT=3306
CRS_PARAM_QUERY_EXTERNAL_MYSQL_USER=test_code
CRS_PARAM_QUERY_EXTERNAL_MYSQL_PASSWORD=
CRS_PARAM_QUERY_EXTERNAL_MYSQL_DATABASE=decoder_sit


# Aliyun OSS image upload
# Browser uploads chat images directly to OSS using a short-lived backend policy.
# Long-lived AK/SK stay on the backend. Leave OSS AK/SK empty to reuse Aliyun
# speech AK/SK or generic ALIYUN_ACCESS_KEY_ID / ALIBABA_CLOUD_ACCESS_KEY_ID
# environment variables.
CRS_ALIYUN_OSS_IMAGE_UPLOAD_ENABLED=true
CRS_ALIYUN_OSS_ACCESS_KEY_ID=
CRS_ALIYUN_OSS_ACCESS_KEY_SECRET=
CRS_ALIYUN_OSS_BUCKET_NAME=ajie-crs-aidiagosis-image
CRS_ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
CRS_ALIYUN_OSS_REGION=oss-cn-shanghai
CRS_ALIYUN_OSS_IMAGE_DIR=chat_images
CRS_ALIYUN_OSS_POLICY_EXPIRE_SECONDS=900
CRS_ALIYUN_OSS_MAX_IMAGE_MB=8
CRS_ALIYUN_OSS_DELETE_ENABLED=true
CRS_ALIYUN_OSS_DELETE_TOKEN_SECRET=
CRS_ALIYUN_OSS_DELETE_TOKEN_EXPIRE_SECONDS=604800
CRS_ALIYUN_OSS_DELETE_WORKER_INTERVAL_SECONDS=10
CRS_ALIYUN_OSS_DELETE_WORKER_BATCH_SIZE=20
CRS_ALIYUN_OSS_DELETE_RETRY_BASE_SECONDS=5
CRS_ALIYUN_OSS_DELETE_RETRY_MAX_SECONDS=21600
CRS_ALIYUN_OSS_DELETE_MAX_ATTEMPTS=0


# Aliyun speech
# These values can also be reused by OSS image upload when OSS-specific AK/SK
# are empty.
CRS_ALIYUN_SPEECH_ENABLED=false
CRS_ALIYUN_SPEECH_ACCESS_KEY_ID=
CRS_ALIYUN_SPEECH_ACCESS_KEY_SECRET=
CRS_ALIYUN_SPEECH_APP_KEY=
CRS_ALIYUN_SPEECH_REGION_ID=cn-shanghai
CRS_ALIYUN_SPEECH_TOKEN_URL=https://nls-meta.cn-shanghai.aliyuncs.com/
CRS_ALIYUN_SPEECH_WS_URL=wss://nls-gateway-cn-shanghai.aliyuncs.com/ws/v1
CRS_ALIYUN_SPEECH_TIMEOUT_SECONDS=10
